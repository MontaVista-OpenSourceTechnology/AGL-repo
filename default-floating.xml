<?xml version="1.0" encoding="UTF-8"?>
<manifest>

  <!-- remote servers to query -->
  <remote name="agl"
         fetch="https://gerrit.automotivelinux.org/gerrit/"
         review="https://gerrit.automotivelinux.org/gerrit/"
         pushurl="ssh://gerrit.automotivelinux.org:29418"
  />
  <remote name="yocto" fetch="https://git.yoctoproject.org/" />
  <remote name="github" fetch="https://github.com/" />
  <remote name="openembedded" fetch="https://git.openembedded.org/" />
  <remote name="qtio" fetch="https://code.qt.io/" />

  <!-- defaults -->
  <default remote="agl" sync-j="4" revision="master"/>


  <!-- CORE -->
  <!-- use agl revisions/branches here -->

  <!-- AGL things. -->
  <project name="AGL/meta-agl" path="meta-agl" />
  <project name="AGL/meta-agl-demo" path="meta-agl-demo" />
  <project name="AGL/meta-agl-devel" path="meta-agl-devel" />


  <!-- ALL EXTERNAL REPOS BELOW USE A FIXED REVISION ! -->

  <!-- YOCTO & OE -->

  <!-- Yocto/OpenEmbedded things. -->
  <project name="bitbake" path="external/bitbake" remote="openembedded" revision="2.18" />
  <project name="openembedded-core" path="external/openembedded-core" remote="openembedded" revision="wrynose" />
  <project name="meta-yocto" path="external/meta-yocto" remote="yocto" revision="wrynose" />
  <project name="openembedded/meta-openembedded" path="external/meta-openembedded" remote="github" revision="wrynose" />


  <!-- UPSTREAM COMPONENTS -->

  <!-- meta-virtualization -->
  <project name="meta-virtualization" path="external/meta-virtualization" remote="yocto" revision="wrynose"/>

  <!-- Qt things -->
  <project name="yocto/meta-qt6" path="external/meta-qt6" remote="qtio" revision="6.12"/>

  <!-- Security layer -->
  <project name="meta-security" path="external/meta-security" remote="yocto" revision="wrynose"/>

  <!-- SELinux layer -->
  <project name="meta-selinux" path="external/meta-selinux" remote="yocto" revision="wrynose"/>

  <!-- meta-spdxscanner - support for fossology -->
  <project name="meta-spdxscanner" path="external/meta-spdxscanner" remote="yocto" revision="master"/>

  <!-- meta-flutter -->
  <project name="meta-flutter/meta-flutter" path="external/meta-flutter" remote="github" revision="master"/>
  <project name="meta-flutter/workspace-automation" path="external/workspace-automation" remote="github" revision="main"/>

  <!-- meta-tensorflow -->
  <project name="meta-tensorflow" path="external/meta-tensorflow" remote="yocto" revision="wrynose"/>

  <!-- meta-python-ai -->
  <project name="zboszor/meta-python-ai" path="external/meta-python-ai" remote="github" revision="wrynose"/>

  <!-- meta-ros -->
  <project name="ros/meta-ros" path="external/meta-ros" remote="github" revision="wrynose"/>


  <!-- BSPs -->

  <!-- meta-aws -->
  <project name="aws4embeddedlinux/meta-aws" path="bsp/meta-aws" remote="github" revision="wrynose"/>

  <!-- Renesas Gen3 specific things -->
  <project name="renesas-rcar/meta-renesas" path="bsp/meta-renesas" remote="github" revision="wrynose-dev"/>
  <project name="CogentEmbedded/meta-rcar" path="bsp/meta-rcar" remote="github" revision="v5.9.4-scarthgap"/>
  <project name="AGL/meta-agl-refhw" path="bsp/meta-agl-refhw" />

  <!-- Renesas R-Car V4H Sparrow-Hawk -->
  <project name="rcar-community/meta-sparrow-hawk" path="bsp/meta-sparrow-hawk" remote="github" revision="wrynose-dev"/>

  <!-- consolidate on meta-freescale from git.yoctoproject.org -->
  <project name="meta-freescale" path="bsp/meta-freescale" remote="yocto" revision="wrynose"/>
  <project name="Freescale/meta-freescale-3rdparty" path="bsp/meta-freescale-3rdparty" remote="github" revision="wrynose"/>

  <!-- TI Vayu / Jacinto 6 / DRA7 -->
  <project name="meta-arm" path="bsp/meta-arm" remote="yocto" revision="wrynose"/>
  <project name="meta-ti" path="bsp/meta-ti" remote="yocto" revision="wrynose"/>

  <!-- Raspberry Pi -->
  <project name="meta-raspberrypi" path="bsp/meta-raspberrypi" remote="yocto" revision="master"/>

  <!-- meta-sifive -->
  <project name="sifive/meta-sifive" path="bsp/meta-sifive" remote="github" revision="wrynose"/>

  <!-- meta-riscv for several risc boards -->
  <project name="riscv/meta-riscv" path="bsp/meta-riscv" remote="github" revision="wrynose"/>

  <!-- meta-tegra -->
  <project name="OE4T/meta-tegra" path="bsp/meta-tegra" remote="github" revision="wrynose"/>

  <!-- rockchip layers -->
  <project name="meta-rockchip" path="bsp/meta-rockchip" remote="yocto" revision="wrynose"/>

</manifest>
